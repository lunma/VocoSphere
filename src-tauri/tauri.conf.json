{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VocoSphere",
  "version": "0.1.0",
  "identifier": "com.vocosphere.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "VocoSphere",
        "width": 1280,
        "height": 832,
        "minWidth": 1024,
        "minHeight": 720,
        "center": true
      },
      {
        "label": "subtitle-overlay",
        "title": "VocoSphere Subtitle",
        "url": "subtitle-overlay.html",
        "width": 600,
        "height": 80,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "resizable": true,
        "focus": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "macOS": {
      "signingIdentity": null,
      "entitlements": null
    },
    "windows": {}
  }
}


